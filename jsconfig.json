{
	"compilerOptions": {
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"target": "ES2024",
		"jsx": "react-jsx",
		"allowImportingTsExtensions": true,
		"checkJs": true,
		"experimentalDecorators": false,
		"strictNullChecks": true,
		"strictFunctionTypes": true,
		"strict": false
	},
	"exclude": ["node_modules", "**/node_modules/*"]
}
